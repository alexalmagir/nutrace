# ==============================================================================
# Nutrace — .gitignore
# Governance: see PUBLISHING_POLICY.md and PUBLIC_PRIVATE_MAP.md
# ==============================================================================

# ------------------------------------------------------------------------------
# SECRETS — never commit
# ------------------------------------------------------------------------------
.mcp.json
.env
.env.local
.env.*.local
*.pem
*.key
*credentials*
secrets/

# ------------------------------------------------------------------------------
# PRIVATE: operational memory + governance
# CLAUDE.md is working memory for the agent system — not a public artifact.
# Governance and classification files are internal controls.
# ------------------------------------------------------------------------------
CLAUDE.md
PUBLISHING_POLICY.md
PUBLIC_PRIVATE_MAP.md

# ------------------------------------------------------------------------------
# PRIVATE: Claude Code operating system
# Raw agent definitions, operational rules, and reusable skills stay local.
# Public-facing summaries live in docs/public/.
# ------------------------------------------------------------------------------
.claude/agents/
.claude/rules/
.claude/skills/
.claude/settings.local.json
.claude/cache/
.claude/logs/

# ------------------------------------------------------------------------------
# OS / editor
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# ------------------------------------------------------------------------------
# Node / Python build artifacts
# ------------------------------------------------------------------------------
node_modules/
__pycache__/
*.pyc
.venv/
venv/
dist/
build/
.next/
.cache/

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
